<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyAppCalcul" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@null</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">#1C344D</item>
        <item name="android:windowBackground">#1C344D</item>
    </style>

    <style name="Theme.MyAppCalcul" parent="Base.Theme.MyAppCalcul" />
    <style name="CalcButtonBlue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/button_scientific</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="CalcButtonDark" parent="CalcButtonBlue">
        <item name="android:background">@drawable/button_numeby</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="CalcButtonOrange" parent="CalcButtonBlue">
        <item name="android:background">@drawable/button_orange</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>